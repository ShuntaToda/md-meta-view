{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/cli/**/*",
    "src/server/**/*",
    "src/core/**/*"
  ],
  "exclude": [
    "src/client/**/*",
    "**/*.test.ts"
  ]
}
