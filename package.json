{
  "name": "md-meta-view",
  "version": "0.2.7",
  "description": "A CLI tool to browse Markdown files with YAML frontmatter in a browser-based table UI",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShuntaToda/md-meta-view.git"
  },
  "keywords": [
    "markdown",
    "frontmatter",
    "viewer",
    "cli",
    "table"
  ],
  "bin": {
    "md-meta-view": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.cli.json && vite build",
    "build:cli": "tsc --project tsconfig.cli.json",
    "build:client": "vite build",
    "dev": "pnpm build:cli && node dist/cli/index.js .",
    "lint": "biome check .",
    "format": "biome format . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "cac": "^7.0.0",
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.7.10",
    "open": "^11.0.0",
    "picomatch": "^4.0.4",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.3.0",
    "@biomejs/biome": "^2.4.9",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-table": "^8.21.3",
    "@types/node": "^24.12.0",
    "@types/picomatch": "^4.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.8.0",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.11.1"
}
